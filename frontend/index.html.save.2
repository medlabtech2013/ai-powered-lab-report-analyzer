<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>CliniSight AI™ Clinical Intelligence Platform</title>

<link rel="stylesheet" href="/static/style.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
/* ===== Hospital Grade UI Styling ===== */

body {
    font-family: "Segoe UI", Arial, sans-serif;
    background-color: #f4f6f9;
    color: #1f2937;
    margin: 30px;
}

h1 {
    color: #0f172a;
}

h2 {
    margin-top: 25px;
    border-bottom: 2px solid #d1d5db;
    padding-bottom: 6px;
}

input, button {
    padding: 6px 10px;
    margin: 4px 0;
    border-radius: 4px;
    border: 1px solid #cbd5e1;
}

button {
    background-color: #0b5cab;
    color: white;
    cursor: pointer;
}

button:hover {
    background-color: #084a8c;
}

table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 12px;
    background: white;
}

th {
    background-color: #e5e7eb;
    text-align: left;
}

th, td {
    border: 1px solid #d1d5db;
    padding: 8px;
}

/* Row Highlights */
tr.high {
    background-color: #fde8e8;
}

tr.low {
    background-color: #e6f0ff;
}

/* Flag Badges */
.flag-badge {
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 12px;
    font-size: 13px;
}

.flag-high {
    background-color: #b91c1c;
    color: white;
}

.flag-low {
    background-color: #1e3a8a;
    color: white;
}

/* Insight Box */
.insight-box {
    margin-top: 10px;
    padding: 10px;
    border-left: 4px solid #64748b;
    background-color: #f1f5f9;
}
</style>
</head>

<body>

<h1>CliniSight AI™ Clinical Intelligence Platform</h1>

<h2>Patient Information</h2>

<label>
<input type="checkbox" id="demoToggle" onchange="toggleDemoMode()" />
Demo Mode
</label>
<br><br>

Name:
<input type="text" id="patientName" value="Branden Bryant">
&nbsp;&nbsp;

DOB:
<input type="date" id="dob" value="1986-12-03">
&nbsp;&nbsp;

MRN:
<input type="text" id="mrn" value="123456">

<br><br>

<input type="file" id="fileInput">
<button onclick="analyze()">Analyze</button>
<button onclick="downloadPDF()">Download PDF</button>
<button onclick="downloadFHIR()">Download FHIR (JSON)</button>

<h2>Clinical Summary</h2>
<div id="summary" class="insight-box">—</div>

<h2>Observations</h2>

<table>
<thead>
<tr>
<th>Test</th>
<th>Value</th>
<th>Units</th>
<th>Reference</th>
<th>Flag</th>
<th>LOINC</th>
</tr>
</thead>
<tbody id="results"></tbody>
</table>

<h2>Trend Analysis</h2>
<canvas id="trendChart" width="600" height="300"></canvas>
<button onclick="loadTrends()">Load Trends</button>

<script>

let lastResult = null;
let chart = null;

function toggleDemoMode() {
    const demo = document.getElementById("demoToggle").checked;
    if (demo) {
        document.getElementById("patientName").value = "Demo Patient";
        document.getElementById("dob").value = "1985-06-15";
        document.getElementById("mrn").value = "DEMO-001";
    }
}

async function analyze() {

    const file = document.getElementById("fileInput").files[0];
    if (!file) {
        alert("Please select an HL7 file.");
        return;
    }

    const formData = new FormData();
    formData.append("file", file);

    try {

        const res = await fetch("/analyze", {
            method: "POST",
            body: formData
        });

        if (!res.ok) throw new Error("Server error");

        const data = await res.json();
        lastResult = data;

        document.getElementById("summary").innerText =
            data.summary || "No clinical insight generated.";

        const tbody = document.getElementById("results");
        tbody.innerHTML = "";

        (data.observations || []).forEach(o => {

            const tr = document.createElement("tr");

            const flag = (o.flag || "").trim().toUpperCase();

            if (flag === "H") tr.classList.add("high");
            if (flag === "L") tr.classList.add("low");

            const flagClass =
                flag === "H" ? "flag-high" :
                flag === "L" ? "flag-low" :
                "";

            tr.innerHTML = `
                <td>${o.test || ""}</td>
                <td>${o.value || ""}</td>
                <td>${o.units || ""}</td>
                <td>${o.reference || ""}</td>
                <td>${flag ? `<span class="flag-badge ${flagClass}">${flag}</span>` : ""}</td>
                <td>${o.loinc || ""}</td>
            `;

            tbody.appendChild(tr);
        });

    } catch (err) {
        console.error(err);
        alert("Analyze failed. Check console.");
    }
}

async function downloadPDF() {

    if (!lastResult) {
        alert("Run Analyze first.");
        return;
    }

    const payload = {
        patient_name: document.getElementById("patientName").value,
        dob: document.getElementById("dob").value,
        mrn: document.getElementById("mrn").value,
        summary: lastResult.summary,
        observations: lastResult.observations
    };

    const res = await fetch("/export/pdf", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
    });

    const blob = await res.blob();
    const url = window.URL.createObjectURL(blob);
    window.open(url);
}

async function downloadFHIR() {

    if (!lastResult) {
        alert("Run Analyze first.");
        return;
    }

    const payload = {
        patient_name: document.getElementById("patientName").value,
        dob: document.getElementById("dob").value,
        mrn: document.getElementById("mrn").value,
        observations: lastResult.observations
    };

    const res = await fetch("/export/fhir", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
    });

    const blob = await res.blob();
    const url = window.URL.createObjectURL(blob);
    window.open(url);
}

async function loadTrends() {

    const res = await fetch("/trends");
    const data = await res.json();

    const labels = Array.from(
        { length: Object.values(data)[0]?.length || 0 },
        (_, i) => `Visit ${i + 1}`
    );

    const datasets = Object.keys(data).map(test => ({
        label: test,
        data: data[test],
        borderWidth: 2,
        fill: false
    }));

    const ctx = document.getElementById("trendChart").getContext("2d");

    if (chart) chart.destroy();

    chart = new Chart(ctx, {
        type: "line",
        data: { labels, datasets },
        options: {
            responsive: true,
            plugins: {
                legend: { position: "top" },
                title: { display: true, text: "Lab Trends Over Time" }
            }
        }
    });
}

</script>

</body>
</html>
